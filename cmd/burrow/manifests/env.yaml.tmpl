# Burrow per-environment namespace + RBAC, rendered by `burrow env add` (ADR-0035 phase 2).
# Namespace-per-environment: one cluster, several app namespaces, one per environment. This creates
# the environment's namespace and grants burrowd a Role there — the SAME app-namespace Role install
# grants in the default app namespace, shared verbatim through the appNamespaceRole template so the
# two cannot drift. `burrow env add` applies this with the user's kubeconfig because burrowd holds
# only namespaced Roles and cannot create namespaces or RBAC itself (least privilege).
#
# .AppNamespace is the environment's namespace; .Namespace is the control-plane namespace where
# burrowd's ServiceAccount lives; .ServiceAccount is that ServiceAccount's name.
apiVersion: v1
kind: Namespace
metadata:
  name: {{.AppNamespace}}
  labels: { app.kubernetes.io/managed-by: burrow }
---
{{ template "appNamespaceRole" . }}
