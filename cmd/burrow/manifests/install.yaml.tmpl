# Burrow control-plane install manifests, rendered by `burrow install` (text/template).
# Bundles everything Burrow needs in the cluster: the namespace, a least-privilege
# ServiceAccount (manage Deployments, read Pods/logs), an in-cluster Postgres for
# control-plane state (ADR-0012), the secrets, and burrowd.
apiVersion: v1
kind: Namespace
metadata:
  name: {{.Namespace}}
  labels: { app.kubernetes.io/managed-by: burrow }
{{- if and (ne .AppNamespace "default") (ne .AppNamespace .Namespace) }}
---
apiVersion: v1
kind: Namespace
metadata:
  name: {{.AppNamespace}}
  labels: { app.kubernetes.io/managed-by: burrow }
{{- end }}
{{- if and (ne .AddonNamespace .Namespace) (ne .AddonNamespace .AppNamespace) }}
---
# Add-ons (curated backing services like the logs store and their collectors) get their own
# namespace: kept out of the app namespace so they don't clutter user workloads, and out of
# the control-plane namespace so a log store's contents never share the credential blast
# radius (ADR-0025).
apiVersion: v1
kind: Namespace
metadata:
  name: {{.AddonNamespace}}
  labels: { app.kubernetes.io/managed-by: burrow }
{{- end }}
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: burrowd
  namespace: {{.Namespace}}
---
# The control plane manages app workloads in the app namespace, so its Role and binding
# live there (the ServiceAccount itself lives in the control-plane namespace).
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: burrowd
  namespace: {{.AppNamespace}}
rules:
  - apiGroups: ["apps"]
    resources: ["deployments"]
    verbs: ["get", "list", "watch", "create", "update", "patch", "delete"]
  - apiGroups: [""]
    resources: ["pods"]
    verbs: ["get", "list"]
  - apiGroups: [""]
    resources: ["pods/log"]
    verbs: ["get"]
  # Exposing an app creates a Service and an Ingress routing a host to it (ADR-0018).
  - apiGroups: [""]
    resources: ["services"]
    verbs: ["get", "list", "create", "update", "patch", "delete"]
  - apiGroups: ["networking.k8s.io"]
    resources: ["ingresses"]
    verbs: ["get", "list", "create", "update", "patch", "delete"]
  # burrowd reads each app's per-app env Secret (burrow-app-<app>-secrets) to LIST its keys and
  # UNSET a key, and create/update let it WRITE a secret value it received over the authenticated
  # control-plane API (ADR-0029) — and let a future provisioned backend (e.g. the Postgres add-on)
  # write a connection string into the app's Secret. Secret values still never cross MCP (there is
  # no secret-set MCP tool) and are never logged or stored in the database (ADR-0029/0004). This is
  # a deliberate, documented broadening of the least-privilege posture (ADR-0023), scoped to the
  # app namespace ONLY: burrowd gets no secrets access in the control-plane or add-on namespaces.
  - apiGroups: [""]
    resources: ["secrets"]
    verbs: ["get", "list", "create", "update"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: burrowd
  namespace: {{.AppNamespace}}
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: Role
  name: burrowd
subjects:
  - kind: ServiceAccount
    name: burrowd
    namespace: {{.Namespace}}
---
# Add-ons live in their own namespace (ADR-0025), so burrowd's permission to manage them is
# scoped there: a logs store is a Deployment + Service + PVC, its collector a DaemonSet +
# ConfigMap. None of these grants reach the app or control-plane namespaces.
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: burrowd-addons
  namespace: {{.AddonNamespace}}
rules:
  - apiGroups: ["apps"]
    resources: ["deployments", "daemonsets"]
    verbs: ["get", "list", "create", "update", "patch", "delete"]
  - apiGroups: [""]
    resources: ["services", "persistentvolumeclaims", "configmaps"]
    verbs: ["get", "list", "create", "update", "patch", "delete"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: burrowd-addons
  namespace: {{.AddonNamespace}}
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: Role
  name: burrowd-addons
subjects:
  - kind: ServiceAccount
    name: burrowd
    namespace: {{.Namespace}}
---
# vmagent (the metrics add-on's scraper) needs read-only pod discovery in the app namespace;
# pre-provisioned so burrowd never creates RBAC. The ServiceAccount lives in the add-on
# namespace (vmagent runs there), the Role grants nothing but get/list/watch on pods, and the
# RoleBinding in the app namespace binds that Role to the add-on-namespace ServiceAccount.
apiVersion: v1
kind: ServiceAccount
metadata:
  name: burrow-vmagent
  namespace: {{.AddonNamespace}}
---
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: burrow-vmagent
  namespace: {{.AppNamespace}}
rules:
  - apiGroups: [""]
    resources: ["pods"]
    verbs: ["get", "list", "watch"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: burrow-vmagent
  namespace: {{.AppNamespace}}
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: Role
  name: burrow-vmagent
subjects:
  - kind: ServiceAccount
    name: burrow-vmagent
    namespace: {{.AddonNamespace}}
---
apiVersion: v1
kind: Secret
metadata:
  name: burrowd-api-token
  namespace: {{.Namespace}}
type: Opaque
stringData:
  token: "{{.Token}}"
---
apiVersion: v1
kind: Secret
metadata:
  name: burrowd-db
  namespace: {{.Namespace}}
type: Opaque
stringData:
  password: "{{.DBPassword}}"
  url: "postgres://burrow:{{.DBPassword}}@postgres:5432/burrow?sslmode=disable"
---
# The vendor-credential Secret (ADR-0023, ADR-0030): one opaque bag of provider tokens, one key
# per provider. Install creates it empty; `burrow provider add` sends the token over burrowd's
# authenticated control-plane API, which writes the key here through the scoped Role below.
apiVersion: v1
kind: Secret
metadata:
  name: burrow-credentials
  namespace: {{.Namespace}}
type: Opaque
---
# burrowd reads provider tokens from burrow-credentials at call time so a rotation needs no
# restart, and writes a token value it received over its authenticated control-plane API
# (ADR-0023, ADR-0030). This is its only access to a Secret's contents: get and update on exactly
# that one object in the control-plane namespace — not list, not watch, not create, and no other
# Secret.
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: burrowd-credentials
  namespace: {{.Namespace}}
rules:
  - apiGroups: [""]
    resources: ["secrets"]
    resourceNames: ["burrow-credentials"]
    verbs: ["get", "update"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: burrowd-credentials
  namespace: {{.Namespace}}
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: Role
  name: burrowd-credentials
subjects:
  - kind: ServiceAccount
    name: burrowd
    namespace: {{.Namespace}}
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: postgres-data
  namespace: {{.Namespace}}
spec:
  accessModes: ["ReadWriteOnce"]
  resources:
    requests:
      storage: 1Gi
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: postgres
  namespace: {{.Namespace}}
spec:
  replicas: 1
  selector: { matchLabels: { app: postgres } }
  strategy: { type: Recreate }
  template:
    metadata: { labels: { app: postgres } }
    spec:
      containers:
        - name: postgres
          image: postgres:18
          env:
            - { name: POSTGRES_USER, value: burrow }
            - { name: POSTGRES_DB, value: burrow }
            - name: POSTGRES_PASSWORD
              valueFrom: { secretKeyRef: { name: burrowd-db, key: password } }
            - { name: PGDATA, value: /var/lib/postgresql/data/pgdata }
          ports: [ { containerPort: 5432 } ]
          readinessProbe:
            exec: { command: ["pg_isready", "-U", "burrow", "-d", "burrow"] }
            initialDelaySeconds: 5
            periodSeconds: 5
          volumeMounts:
            - { name: data, mountPath: /var/lib/postgresql/data }
      volumes:
        - name: data
          persistentVolumeClaim: { claimName: postgres-data }
---
apiVersion: v1
kind: Service
metadata:
  name: postgres
  namespace: {{.Namespace}}
spec:
  selector: { app: postgres }
  ports: [ { port: 5432, targetPort: 5432 } ]
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: burrowd
  namespace: {{.Namespace}}
  labels: { app: burrowd }
spec:
  replicas: 1
  selector: { matchLabels: { app: burrowd } }
  template:
    metadata: { labels: { app: burrowd } }
    spec:
      serviceAccountName: burrowd
      containers:
        - name: burrowd
          image: {{.Image}}
          args: ["-listen=:{{.Port}}"]
          env:
            - { name: BURROW_NAMESPACE, value: {{.AppNamespace}} }
            - { name: BURROW_ADDON_NAMESPACE, value: {{.AddonNamespace}} }
            # POD_NAMESPACE is burrowd's own (control-plane) namespace, where it reads the
            # burrow-credentials Secret — distinct from BURROW_NAMESPACE, the app namespace.
            - name: POD_NAMESPACE
              valueFrom: { fieldRef: { fieldPath: metadata.namespace } }
            - name: BURROW_API_TOKEN
              valueFrom: { secretKeyRef: { name: burrowd-api-token, key: token } }
            - name: BURROW_DATABASE_URL
              valueFrom: { secretKeyRef: { name: burrowd-db, key: url } }
          ports: [ { containerPort: {{.Port}} } ]
          readinessProbe:
            httpGet: { path: /healthz, port: {{.Port}} }
            initialDelaySeconds: 3
            periodSeconds: 5
---
apiVersion: v1
kind: Service
metadata:
  name: burrowd
  namespace: {{.Namespace}}
spec:
  selector: { app: burrowd }
  ports: [ { port: {{.Port}}, targetPort: {{.Port}} } ]
