# Burrow control-plane install manifests, rendered by `burrow install` (text/template).
# Bundles everything Burrow needs in the cluster: the namespace, a least-privilege
# ServiceAccount (manage Deployments, read Pods/logs), an in-cluster Postgres for
# control-plane state (ADR-0012), the secrets, and burrowd.
apiVersion: v1
kind: Namespace
metadata:
  name: {{.Namespace}}
  labels: { app.kubernetes.io/managed-by: burrow }
{{- if and (ne .AppNamespace "default") (ne .AppNamespace .Namespace) }}
---
apiVersion: v1
kind: Namespace
metadata:
  name: {{.AppNamespace}}
  labels: { app.kubernetes.io/managed-by: burrow }
{{- end }}
{{- if and (ne .AddonNamespace .Namespace) (ne .AddonNamespace .AppNamespace) }}
---
# Add-ons (curated backing services like the logs store and their collectors) get their own
# namespace: kept out of the app namespace so they don't clutter user workloads, and out of
# the control-plane namespace so a log store's contents never share the credential blast
# radius (ADR-0025).
apiVersion: v1
kind: Namespace
metadata:
  name: {{.AddonNamespace}}
  labels: { app.kubernetes.io/managed-by: burrow }
{{- end }}
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: burrowd
  namespace: {{.Namespace}}
---
{{ template "appNamespaceRole" . }}
---
# Add-ons live in their own namespace (ADR-0025), so burrowd's permission to manage them is
# scoped there: a logs store is a Deployment + Service + PVC, its collector a DaemonSet +
# ConfigMap; the Postgres add-on (ADR-0031) adds a Secret, burrow-postgres, holding the generated
# superuser password — burrowd creates it before the pod and reads it back to run admin SQL. The
# secrets grant is namespace-scoped to the add-on namespace ONLY (not name-scoped, not a
# ClusterRole): none of these grants reach the app or control-plane namespaces.
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: burrowd-addons
  namespace: {{.AddonNamespace}}
rules:
  - apiGroups: ["apps"]
    resources: ["deployments", "daemonsets"]
    verbs: ["get", "list", "create", "update", "patch", "delete"]
  - apiGroups: [""]
    resources: ["services", "persistentvolumeclaims", "configmaps"]
    verbs: ["get", "list", "create", "update", "patch", "delete"]
  # The Postgres add-on's superuser Secret (burrow-postgres) lives in this namespace because a pod
  # can only mount a Secret in its own namespace (ADR-0031). burrowd creates it, reads it to run
  # admin SQL, and deletes it on uninstall — scoped to this add-on namespace only.
  - apiGroups: [""]
    resources: ["secrets"]
    verbs: ["get", "create", "update", "delete"]
  # Postgres backup/restore run as short-lived Jobs in this namespace that pg_dump/pg_restore an
  # app's database to the backup PVC (ADR-0032). burrowd creates and reaps them and reads their
  # status; the Jobs read the superuser password from burrow-postgres via secretKeyRef.
  - apiGroups: ["batch"]
    resources: ["jobs"]
    verbs: ["get", "list", "create", "delete"]
  # ... and reads the backup Job's pod to recover the dump's byte size from the terminated
  # container's termination-message (ADR-0032). Read-only on pods, scoped to this namespace.
  - apiGroups: [""]
    resources: ["pods"]
    verbs: ["get", "list"]
  # Read-only check that an add-on's pre-provisioned ServiceAccount exists before burrowd deploys
  # that add-on's workload (e.g. the metrics scraper's ServiceAccount, which the CLI applies
  # kubeconfig-side at install time). Get ONLY — no create/update/delete on serviceaccounts, so this
  # grants burrowd no RBAC-escalation power; it can verify the grant exists but never mint one.
  # Scoped to the add-on namespace.
  - apiGroups: [""]
    resources: ["serviceaccounts"]
    verbs: ["get"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: burrowd-addons
  namespace: {{.AddonNamespace}}
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: Role
  name: burrowd-addons
subjects:
  - kind: ServiceAccount
    name: burrowd
    namespace: {{.Namespace}}
---
apiVersion: v1
kind: Secret
metadata:
  name: burrowd-api-token
  namespace: {{.Namespace}}
type: Opaque
stringData:
  token: "{{.Token}}"
---
apiVersion: v1
kind: Secret
metadata:
  name: burrowd-db
  namespace: {{.Namespace}}
type: Opaque
stringData:
  password: "{{.DBPassword}}"
  url: "postgres://burrow:{{.DBPassword}}@postgres:5432/burrow?sslmode=disable"
---
# The vendor-credential Secret (ADR-0023, ADR-0030): one opaque bag of provider tokens, one key
# per provider. Install creates it empty; `burrow provider add` sends the token over burrowd's
# authenticated control-plane API, which writes the key here through the scoped Role below.
apiVersion: v1
kind: Secret
metadata:
  name: burrow-credentials
  namespace: {{.Namespace}}
type: Opaque
---
# burrowd reads provider tokens from burrow-credentials at call time so a rotation needs no
# restart, and writes a token value it received over its authenticated control-plane API
# (ADR-0023, ADR-0030). This is its only access to a Secret's contents: get and update on exactly
# that one object in the control-plane namespace — not list, not watch, not create, and no other
# Secret.
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: burrowd-credentials
  namespace: {{.Namespace}}
rules:
  - apiGroups: [""]
    resources: ["secrets"]
    resourceNames: ["burrow-credentials"]
    verbs: ["get", "update"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: burrowd-credentials
  namespace: {{.Namespace}}
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: Role
  name: burrowd-credentials
subjects:
  - kind: ServiceAccount
    name: burrowd
    namespace: {{.Namespace}}
---
# The scoped agent credential (ADR-0038): a ServiceAccount whose reachable capability is EXACTLY
# "the guardrailed control plane" and nothing else. `burrow install` mints a long-lived token for
# it (the Secret below) and writes a self-contained, burrowd-only kubeconfig under ~/.burrow/; the
# agent — and any `kubectl` it shells out to — is confined to reaching burrowd by this Role. The
# human keeps their own admin kubeconfig for privileged and governance work. All users' agents
# share this one ServiceAccount for now; per-user ServiceAccounts are a deliberate, additive future
# step tied to SSO (ADR-0038 §5).
apiVersion: v1
kind: ServiceAccount
metadata:
  name: {{.AgentServiceAccount}}
  namespace: {{.Namespace}}
---
# The agent's ENTIRE grant: proxy access to the burrowd Service (so the client reaches burrowd
# through the Kubernetes API-server proxy, ADR-0014) and `get` on the burrowd-api-token Secret so
# it can read the control-plane API token. Both are resourceNames-scoped to exactly those objects.
# There is nothing else: no pods, no other services, no other secrets, no list/watch, no other
# namespace, no cluster-scoped read — so the guardrails in burrowd become binding by construction
# (ADR-0021), not merely by shell-denies.
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: {{.AgentServiceAccount}}
  namespace: {{.Namespace}}
rules:
  - apiGroups: [""]
    resources: ["services/proxy"]
    resourceNames: ["burrowd", "burrowd:{{.Port}}", "http:burrowd:", "https:burrowd:"]
    verbs: ["get", "create", "update", "patch", "delete"]
  - apiGroups: [""]
    resources: ["secrets"]
    resourceNames: ["burrowd-api-token"]
    verbs: ["get"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: {{.AgentServiceAccount}}
  namespace: {{.Namespace}}
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: Role
  name: {{.AgentServiceAccount}}
subjects:
  - kind: ServiceAccount
    name: {{.AgentServiceAccount}}
    namespace: {{.Namespace}}
---
# A long-lived ServiceAccount token for the agent (ADR-0038 §3). The token controller populates
# .data.token and .data["ca.crt"] once this Secret exists; `burrow install` polls for that and mints
# the scoped kubeconfig from it. A long-lived token is acceptable because the RBAC narrowness above
# is the real control and the token is revocable by deleting this Secret or the ServiceAccount; a
# bound short-lived token (TokenRequest) or a client certificate are noted future tightenings.
apiVersion: v1
kind: Secret
metadata:
  name: burrow-agent-token
  namespace: {{.Namespace}}
  annotations:
    kubernetes.io/service-account.name: {{.AgentServiceAccount}}
type: kubernetes.io/service-account-token
---
# The ONE cluster-scoped grant burrowd holds (ADR-0034). It is read-only — get/list only — on
# non-sensitive cluster-capability metadata: nodes (to infer the cloud provider), storageclasses
# (the default StorageClass), and ingressclasses (which ingress controller is installed). This is
# what lets burrowd answer "what can this cluster do" live, so the agent sees capabilities even
# after an out-of-band `kubectl apply`. Detecting cert-manager and other operators needs NO RBAC —
# it is done via API-group discovery. There is NOTHING else here: no secrets, no writes, no other
# resources, no other verbs. burrowd's write surface stays exactly as namespaced as before; this is
# the only, measured, read-only exception to the otherwise-namespaced model.
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: burrowd-cluster-capabilities
rules:
  - apiGroups: [""]
    resources: ["nodes"]
    verbs: ["get", "list"]
  - apiGroups: ["storage.k8s.io"]
    resources: ["storageclasses"]
    verbs: ["get", "list"]
  - apiGroups: ["networking.k8s.io"]
    resources: ["ingressclasses"]
    verbs: ["get", "list"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: burrowd-cluster-capabilities
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: burrowd-cluster-capabilities
subjects:
  - kind: ServiceAccount
    name: burrowd
    namespace: {{.Namespace}}
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: postgres-data
  namespace: {{.Namespace}}
spec:
  accessModes: ["ReadWriteOnce"]
  resources:
    requests:
      storage: 1Gi
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: postgres
  namespace: {{.Namespace}}
spec:
  replicas: 1
  selector: { matchLabels: { app: postgres } }
  strategy: { type: Recreate }
  template:
    metadata: { labels: { app: postgres } }
    spec:
      containers:
        - name: postgres
          image: postgres:18
          env:
            - { name: POSTGRES_USER, value: burrow }
            - { name: POSTGRES_DB, value: burrow }
            - name: POSTGRES_PASSWORD
              valueFrom: { secretKeyRef: { name: burrowd-db, key: password } }
            - { name: PGDATA, value: /var/lib/postgresql/data/pgdata }
          ports: [ { containerPort: 5432 } ]
          readinessProbe:
            exec: { command: ["pg_isready", "-U", "burrow", "-d", "burrow"] }
            initialDelaySeconds: 5
            periodSeconds: 5
          volumeMounts:
            - { name: data, mountPath: /var/lib/postgresql/data }
      volumes:
        - name: data
          persistentVolumeClaim: { claimName: postgres-data }
---
apiVersion: v1
kind: Service
metadata:
  name: postgres
  namespace: {{.Namespace}}
spec:
  selector: { app: postgres }
  ports: [ { port: 5432, targetPort: 5432 } ]
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: burrowd
  namespace: {{.Namespace}}
  labels: { app: burrowd }
spec:
  replicas: 1
  selector: { matchLabels: { app: burrowd } }
  template:
    metadata: { labels: { app: burrowd } }
    spec:
      serviceAccountName: burrowd
      containers:
        - name: burrowd
          image: {{.Image}}
          args: ["-listen=:{{.Port}}"]
          env:
            - { name: BURROW_NAMESPACE, value: {{.AppNamespace}} }
            - { name: BURROW_ADDON_NAMESPACE, value: {{.AddonNamespace}} }
            # POD_NAMESPACE is burrowd's own (control-plane) namespace, where it reads the
            # burrow-credentials Secret — distinct from BURROW_NAMESPACE, the app namespace.
            - name: POD_NAMESPACE
              valueFrom: { fieldRef: { fieldPath: metadata.namespace } }
            - name: BURROW_API_TOKEN
              valueFrom: { secretKeyRef: { name: burrowd-api-token, key: token } }
            - name: BURROW_DATABASE_URL
              valueFrom: { secretKeyRef: { name: burrowd-db, key: url } }
          ports: [ { containerPort: {{.Port}} } ]
          readinessProbe:
            httpGet: { path: /healthz, port: {{.Port}} }
            initialDelaySeconds: 3
            periodSeconds: 5
---
apiVersion: v1
kind: Service
metadata:
  name: burrowd
  namespace: {{.Namespace}}
spec:
  selector: { app: burrowd }
  ports: [ { port: {{.Port}}, targetPort: {{.Port}} } ]
