# The OPTIONAL lightweight in-cluster registry (ADR-0053 §5, ADR-0054): Zot, the OCI-native
# project-zot registry, chosen for its minimal footprint. It is the zero-config default push target
# for the in-cluster build so a self-hosted user needs no external registry account or pull token;
# external registries remain fully supported. Deploy stays strictly by image reference — this is
# simply a registry that happens to be local.
#
# It is reachable the same way on any cluster (ADR-0054 §5): the build pushes to the INTERNAL ClusterIP
# Service ({{.RegistryEndpoint}}) in-cluster over plain HTTP, credential-free; nodes pull the PUBLIC
# host ({{.Host}}) through the cluster ingress, which terminates TLS with a certificate issued by the
# existing "{{.IssuerName}}" Let's Encrypt ClusterIssuer. No node or containerd editing. The internally
# pushed image and the publicly pulled reference share the same repository path and digest, so they
# resolve to the same stored image. `burrow cluster registry install` applies these resources as a
# standalone, opt-in step (ADR-0054): `burrow install` provisions only the control plane.
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: burrow-registry
  namespace: {{.Namespace}}
  labels: { app: burrow-registry, app.kubernetes.io/managed-by: burrow }
spec:
  accessModes: ["ReadWriteOnce"]
  resources:
    requests:
      # Build layers accumulate, so the registry gets more room than the lean control-plane DB; the
      # GC policy below keeps it from filling (ADR-0053 Consequences).
      storage: 5Gi
---
# Zot's configuration: serve on :{{.RegistryPort}} over plain HTTP (the internal Service and the
# ingress both reach it here; the ingress is what terminates TLS in front of it) and, crucially, run
# garbage collection so orphaned build layers do not fill the volume (ADR-0053 Consequences).
apiVersion: v1
kind: ConfigMap
metadata:
  name: burrow-registry-config
  namespace: {{.Namespace}}
  labels: { app: burrow-registry, app.kubernetes.io/managed-by: burrow }
data:
  config.json: |
    {
      "distSpecVersion": "1.1.0",
      "storage": {
        "rootDirectory": "/var/lib/registry",
        "gc": true,
        "gcDelay": "1h",
        "gcInterval": "24h",
        "retention": {
          "policies": [
            {
              "repositories": ["**"],
              "deleteUntagged": true
            }
          ]
        }
      },
      "http": {
        "address": "0.0.0.0",
        "port": "{{.RegistryPort}}"
      },
      "log": {
        "level": "info"
      }
    }
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: burrow-registry
  namespace: {{.Namespace}}
  labels: { app: burrow-registry, app.kubernetes.io/managed-by: burrow }
spec:
  replicas: 1
  selector: { matchLabels: { app: burrow-registry } }
  # A ReadWriteOnce volume cannot be held by two pods at once, so recreate rather than roll.
  strategy: { type: Recreate }
  template:
    metadata: { labels: { app: burrow-registry } }
    spec:
      containers:
        - name: registry
          image: {{.RegistryImage}}
          args: ["serve", "/etc/zot/config.json"]
          ports: [ { containerPort: {{.RegistryPort}} } ]
          # A registry is lightweight at rest; a modest limit keeps it off a small VPS's back.
          resources:
            requests: { cpu: 25m, memory: 64Mi }
            limits: { memory: 256Mi }
          readinessProbe:
            httpGet: { path: /v2/, port: {{.RegistryPort}} }
            initialDelaySeconds: 3
            periodSeconds: 5
          volumeMounts:
            - { name: data, mountPath: /var/lib/registry }
            - { name: config, mountPath: /etc/zot }
      volumes:
        - name: data
          persistentVolumeClaim: { claimName: burrow-registry }
        - name: config
          configMap: { name: burrow-registry-config }
---
# The INTERNAL push endpoint: a plain ClusterIP Service the build pod pushes to in-cluster over plain
# HTTP at {{.RegistryEndpoint}}. No auth — it is only reachable inside the cluster (ADR-0054 §5).
apiVersion: v1
kind: Service
metadata:
  name: burrow-registry
  namespace: {{.Namespace}}
  labels: { app: burrow-registry, app.kubernetes.io/managed-by: burrow }
spec:
  type: ClusterIP
  selector: { app: burrow-registry }
  ports:
    - port: {{.RegistryPort}}
      targetPort: {{.RegistryPort}}
---
# The PUBLIC pull endpoint: an ingress vhost at {{.Host}} the nodes pull through over TLS (ADR-0054 §5).
# cert-manager issues the certificate via the existing "{{.IssuerName}}" HTTP-01 ClusterIssuer. Two
# annotations are load-bearing: proxy-body-size "0" removes nginx's body cap so large image layers
# push and pull (without it, big layers fail), and the basic-auth annotations require a credential on
# this public path while the internal push path above stays credential-free.
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: burrow-registry
  namespace: {{.Namespace}}
  labels: { app: burrow-registry, app.kubernetes.io/managed-by: burrow }
  annotations:
    cert-manager.io/cluster-issuer: "{{.IssuerName}}"
    nginx.ingress.kubernetes.io/proxy-body-size: "0"
    nginx.ingress.kubernetes.io/proxy-read-timeout: "600"
    nginx.ingress.kubernetes.io/proxy-send-timeout: "600"
    nginx.ingress.kubernetes.io/auth-type: basic
    nginx.ingress.kubernetes.io/auth-secret: "{{.AuthSecretName}}"
    nginx.ingress.kubernetes.io/auth-realm: "Burrow in-cluster registry"
spec:
  ingressClassName: nginx
  tls:
    - hosts: ["{{.Host}}"]
      secretName: "{{.TLSSecretName}}"
  rules:
    - host: "{{.Host}}"
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: burrow-registry
                port:
                  number: {{.RegistryPort}}
